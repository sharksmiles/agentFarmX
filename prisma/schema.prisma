generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model User {
  id                String         @id @default(cuid())
  walletAddress     String         @unique @db.VarChar(42)
  username          String?        @db.VarChar(50)
  avatar            String?        @db.VarChar(255)
  level             Int            @default(1)
  experience        Int            @default(0)
  farmCoins         Int            @default(1000)
  inviteCode        String         @unique @default(cuid()) @db.VarChar(30)
  invitedBy         String?        @db.VarChar(30)
  inviteCount       Int            @default(0)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  lastLoginAt       DateTime       @default(now())
  agents            Agent[]
  farmState         FarmState?
  inventory         Inventory[]
  raffleEntries     RaffleEntry[]
  socialActionsFrom SocialAction[] @relation("SocialActionsFrom")
  socialActionsTo   SocialAction[] @relation("SocialActionsTo")
  transactions      Transaction[]

  @@index([walletAddress])
  @@index([inviteCode])
  @@index([createdAt])
  @@map("users")
}

model FarmState {
  id               String     @id @default(cuid())
  userId           String     @unique
  energy           Int        @default(100)
  maxEnergy        Int        @default(100)
  lastEnergyUpdate DateTime   @default(now())
  unlockedLands    Int        @default(6)
  totalHarvests    Int        @default(0)
  totalPlants      Int        @default(0)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  landPlots        LandPlot[]

  @@index([userId])
  @@map("farm_states")
}

model LandPlot {
  id              String    @id @default(cuid())
  farmStateId     String
  plotIndex       Int
  isUnlocked      Boolean   @default(false)
  cropId          String?   @db.VarChar(50)
  plantedAt       DateTime?
  harvestAt       DateTime?
  growthStage     Int       @default(0)
  lastWateredAt   DateTime?
  nextWateringDue DateTime?
  boostMultiplier Float     @default(1.0)
  boostExpireAt   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  farmState       FarmState @relation(fields: [farmStateId], references: [id], onDelete: Cascade)

  @@unique([farmStateId, plotIndex])
  @@index([farmStateId])
  @@index([harvestAt])
  @@map("land_plots")
}

model Inventory {
  id        String   @id @default(cuid())
  userId    String
  itemType  String   @db.VarChar(50)
  itemId    String   @db.VarChar(50)
  quantity  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, itemType, itemId])
  @@index([userId])
  @@map("inventories")
}

model Agent {
  id             String            @id @default(cuid())
  userId         String
  scaAddress     String            @unique @db.VarChar(42)
  nftTokenId     String?           @db.VarChar(78)
  name           String            @db.VarChar(100)
  personality    String            @db.VarChar(50)
  strategyType   String            @db.VarChar(50)
  aiModel        String            @default("gpt-3.5-turbo") @db.VarChar(50)
  customPrompt   String?
  temperature    Float             @default(0.7)
  status         String            @default("idle") @db.VarChar(20)
  isActive       Boolean           @default(false)
  totalProfit    Int               @default(0)
  totalTasks     Int               @default(0)
  successRate    Float             @default(0.0)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  lastActiveAt   DateTime?
  balanceOkb     Float             @default(0.0)
  balanceUsdc    Float             @default(0.0)
  strategyConfig Json?
  decisions      AgentDecision[]
  logs           AgentLog[]
  skillUsages    AgentSkillUsage[]
  tasks          AgentTask[]
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([scaAddress])
  @@index([status])
  @@map("agents")
}

model AgentTask {
  id          String    @id @default(cuid())
  agentId     String
  taskType    String    @db.VarChar(50)
  taskData    Json
  status      String    @default("pending") @db.VarChar(20)
  priority    Int       @default(0)
  result      Json?
  error       String?
  createdAt   DateTime  @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  agent       Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId])
  @@index([status])
  @@index([createdAt])
  @@map("agent_tasks")
}

model AgentLog {
  id        String   @id @default(cuid())
  agentId   String
  level     String   @db.VarChar(20)
  message   String
  metadata  Json?
  createdAt DateTime @default(now())
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId])
  @@index([createdAt])
  @@map("agent_logs")
}

model AgentSkill {
  id            String            @id @default(cuid())
  name          String            @unique @db.VarChar(100)
  displayName   String            @db.VarChar(100)
  description   String
  category      String            @db.VarChar(50)
  parameters    Json
  energyCost    Int               @default(0)
  cooldown      Int               @default(0)
  requiredLevel Int               @default(1)
  isActive      Boolean           @default(true)
  isSystem      Boolean           @default(true)
  totalUsages   Int               @default(0)
  successCount  Int               @default(0)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  usages        AgentSkillUsage[]

  @@index([category])
  @@index([isActive])
  @@map("agent_skills")
}

model AgentSkillUsage {
  id            String     @id @default(cuid())
  agentId       String
  skillId       String
  parameters    Json
  result        Json?
  success       Boolean    @default(false)
  error         String?
  executionTime Int        @default(0)
  createdAt     DateTime   @default(now())
  agent         Agent      @relation(fields: [agentId], references: [id], onDelete: Cascade)
  skill         AgentSkill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@index([agentId])
  @@index([skillId])
  @@index([createdAt])
  @@map("agent_skill_usages")
}

model AgentDecision {
  id         String   @id @default(cuid())
  agentId    String
  model      String   @db.VarChar(50)
  prompt     String
  response   String
  decisions  Json
  reasoning  String?
  tokensUsed Int      @default(0)
  cost       Float    @default(0.0)
  latency    Int      @default(0)
  executed   Boolean  @default(false)
  success    Boolean  @default(false)
  createdAt  DateTime @default(now())
  agent      Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId])
  @@index([createdAt])
  @@index([model])
  @@map("agent_decisions")
}

model SocialAction {
  id          String   @id @default(cuid())
  actionType  String   @db.VarChar(50)
  rewardCoins Int      @default(0)
  rewardExp   Int      @default(0)
  createdAt   DateTime @default(now())
  fromUserId  String
  metadata    Json?
  toUserId    String
  fromUser    User     @relation("SocialActionsFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser      User     @relation("SocialActionsTo", fields: [toUserId], references: [id], onDelete: Cascade)

  @@index([fromUserId])
  @@index([toUserId])
  @@index([actionType])
  @@index([createdAt])
  @@map("social_actions")
}

model RaffleEntry {
  id           String    @id @default(cuid())
  userId       String
  raffleId     String    @db.VarChar(100)
  ticketCount  Int       @default(1)
  isWinner     Boolean   @default(false)
  prizeType    String?   @db.VarChar(50)
  prizeAmount  String?   @db.VarChar(78)
  txHash       String?   @db.VarChar(66)
  createdAt    DateTime  @default(now())
  claimedAt    DateTime?
  ticketNumber Int
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([raffleId])
  @@index([isWinner])
  @@map("raffle_entries")
}

model Transaction {
  id          String   @id @default(cuid())
  userId      String
  type        String   @db.VarChar(50)
  category    String   @db.VarChar(50)
  amount      Int
  balance     Int
  description String?  @db.VarChar(255)
  metadata    Json?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@map("transactions")
}

model CropConfig {
  id             String   @id @default(cuid())
  cropType       String   @unique @db.VarChar(50)
  unlockLevel    Int      @default(1)
  seedPrice      Int
  matureTime     Int
  wateringPeriod Int
  harvestPrice   Int
  seedingExp     Int
  harvestExp     Int
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([unlockLevel])
  @@map("crop_configs")
}

model LevelConfig {
  id          String   @id @default(cuid())
  level       Int      @unique
  requiredExp Int
  maxLand     Int
  upgradeCost Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([level])
  @@map("level_configs")
}

model SystemConfig {
  id          String   @id @default(cuid())
  key         String   @unique @db.VarChar(100)
  value       Json
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([key])
  @@map("system_configs")
}
