# ── Backend API ───────────────────────────────────────────────────────────────
# Base URL for all /api/* requests (no trailing slash)
NEXT_PUBLIC_API_URL=https://api.agentfarm.example.com

# ── X Layer / On-chain ────────────────────────────────────────────────────────
# USDC contract address on X Layer Mainnet
NEXT_PUBLIC_USDC_ADDRESS=0x74b7f16337b8972027f6196a17a631ac6de26d22


# ── OKX DEX / Swap API (for Trader Agent) ────────────────────────────────────
# Required server-side only — do NOT prefix with NEXT_PUBLIC_
# OKX_API_KEY=
# OKX_SECRET_KEY=
# OKX_PASSPHRASE=
