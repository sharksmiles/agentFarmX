{
  "info": {
    "name": "AgentFarm X API",
    "description": "Complete API collection for AgentFarm X backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3001",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "user_123",
      "type": "string"
    },
